            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            font-size: 1rem;
            transition: background 0.2s;
            display: inline-block;
            text-align: center;
            width: 100%;
            margin-top: 10px;
        }

        .btn:hover {
            background-color: #2563eb;
        }

        .btn-secondary {
            background-color: #475569;
        }

        .btn-secondary:hover {
            background-color: #334155;
        }

        .grid-options {
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
            margin-bottom: 20px;
        }

        @media(min-width: 600px) {
            .grid-options {
                grid-template-columns: 1fr 1fr;
            }
        }

        .option-card {
            background: #1e293b;
            border: 2px solid #334155;
            padding: 20px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .option-card:hover {
            border-color: var(--accent-primary);
            background: #273549;
        }

        .option-card.selected {
            border-color: var(--accent-success);
            background: rgba(16, 185, 129, 0.1);
        }

        .input-field {
            width: 100%;
            padding: 12px;
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 6px;
            color: white;
            margin-bottom: 15px;
            font-size: 1rem;
        }

        .input-field:focus {
            outline: none;
            border-color: var(--accent-primary);
        }

        .prompt-card {
            background-color: var(--prompt-bg);
            border: 1px dashed #4b5563;
            padding: 20px;
            border-radius: 8px;
            margin-top: 25px;
        }

        .prompt-header {
            display: flex;
            align-items: center;
            color: #a78bfa;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 10px;
        }

        .prompt-text {
            font-family: 'Courier New', Courier, monospace;
            font-size: 0.9rem;
            color: #cbd5e1;
            white-space: pre-wrap;
            background: #111827;
            padding: 12px;
            border-radius: 6px;
            user-select: all;
        }

        .progress-container {
            width: 100%;
            background-color: #334155;
            border-radius: 10px;
            height: 8px;
            margin-bottom: 25px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(to right, #3b82f6, #10b981);
            transition: width 0.4s ease;
        }

        .pill-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            background: #334155;
            margin-right: 8px;
            margin-bottom: 8px;
        }

        .roadmap-week {
            border-bottom: 1px solid #334155;
            padding: 15px 0;
        }

        .roadmap-week:last-child {
            border-bottom: none;
        }

        .feedback-box {
            margin-top: 15px;
            padding: 15px;
            border-radius: 6px;
            font-weight: 500;
        }

        .feedback-correct {
            background: rgba(16, 185, 129, 0.15);
            border: 1px solid var(--accent-success);
            color: #34d399;
        }

        .feedback-incorrect {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid var(--accent-danger);
            color: #f87171;
        }
    </style>
</head>
