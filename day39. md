<!DOCTYPE html>
<html lang="hi" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium PDF Splitter & Merger</title>
    <!-- Tailwind CSS -->
    <script src="https://jsdelivr.net"></script>
    <!-- PDF-Lib Library for Client-side processing -->
    <script src="https://unpkg.com"></script>
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #4b5563; border-radius: 3px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #6b7280; }
    </style>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen font-sans flex flex-col antialiased transition-colors duration-300">

    <!-- Top Navigation Header -->
    <header class="border-b border-slate-800 bg-slate-900/50 backdrop-blur sticky top-0 z-50 px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="p-2 bg-rose-600 rounded-xl text-white shadow-lg shadow-rose-600/20">
                <!-- PDF Icon -->
                <svg xmlns="http://w3.org" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
            </div>
            <div>
                <h1 class="text-xl font-bold tracking-tight bg-gradient-to-r from-slate-100 to-slate-400 bg-clip-text text-transparent">PDF Craft</h1>
                <p class="text-xs text-slate-500 font-medium">प्रीमियम क्लाइंट-साइड टूल्स</p>
            </div>
        </div>

        <!-- Mode / Tab Toggles -->
        <div class="flex bg-slate-950 p-1.5 rounded-xl border border-slate-800/80 shadow-inner">
            <button id="tab-splitter" onclick="switchTab('splitter')" class="px-5 py-2 rounded-lg text-sm font-semibold transition-all duration-200 flex items-center gap-2 text-rose-500 bg-slate-900 shadow-sm border border-slate-800">
                <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 12h18"/></svg>
                PDF स्प्लिटर (अलग करें)
            </button>
            <button id="tab-merger" onclick="switchTab('merger')" class="px-5 py-2 rounded-lg text-sm font-semibold transition-all duration-200 flex items-center gap-2 text-slate-400 hover:text-slate-200">
                <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M12 3v18"/></svg>
                PDF मर्जर (जोड़ें)
            </button>
        </div>

        <!-- Privacy Status badge -->
        <div class="hidden sm:flex items-center gap-2 text-emerald-500 text-xs font-semibold bg-emerald-500/10 px-3 py-1.5 rounded-full border border-emerald-500/20">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            100% सुरक्षित (ऑफलाइन काम करता है)
        </div>
    </header>

    <!-- Main Workspace -->
    <main class="flex-1 p-6 max-w-7xl mx-auto w-full grid grid-cols-1 gap-6">
        
        <!-- SECTION 1: PDF SPLITTER -->
        <section id="splitter-section" class="space-y-6">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Dropzone left -->
                <div class="lg:col-span-1 space-y-4">
                    <div id="split-dropzone" class="border-2 border-dashed border-slate-800 hover:border-rose-500/50 bg-slate-900/30 rounded-2xl p-8 text-center cursor-pointer transition-all flex flex-col items-center justify-center min-h-[300px] shadow-sm">
                        <input type="file" id="split-input" accept=".pdf" class="hidden" onchange="handleSplitFile(this.files[0])">
                        <div class="p-4 bg-rose-500/10 rounded-full text-rose-500 mb-4">
                            <svg xmlns="http://w3.org" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
                        </div>
                        <h3 class="font-bold text-slate-200 mb-1">एक PDF फ़ाइल यहाँ छोड़ें या चुनें</h3>
                        <p class="text-xs text-slate-500 max-w-xs">सभी फाइलें स्थानीय रूप से ब्राउज़र के अंदर सुरक्षित संसाधित होती हैं</p>
                    </div>

                    <!-- File Details Container -->
                    <div id="split-file-info" class="hidden bg-slate-900 border border-slate-800 rounded-xl p-4 space-y-3">
                        <div class="flex items-center justify-between">
                            <h4 class="text-sm font-bold text-slate-300 truncate pr-2" id="split-filename">document.pdf</h4>
                            <span class="text-xs font-bold bg-slate-800 text-slate-400 px-2.5 py-1 rounded" id="split-pagecount">0 पेज</span>
                        </div>
                        
                        <hr class="border-slate-800">
                        
                        <!-- Options Group -->
                        <div class="space-y-3">
                            <label class="block text-xs font-bold uppercase text-slate-500 tracking-wider">अलग करने का तरीका</label>
                            <select id="split-method" onchange="toggleSplitInputs()" class="w-full bg-slate-950 border border-slate-800 text-sm rounded-lg p-2.5 text-slate-300 focus:border-rose-500 focus:outline-none">
                                <option value="range">कस्टम रेंज (उदाहरण: 1-3, 5)</option>
                                <option value="every">प्रत्येक N पेजों में बाँटें</option>
                            </select>

                            <!-- Dynamic Inputs based on selection -->
                            <div id="method-range-input" class="space-y-1.5">
                                <label class="text-xs text-slate-400">पेज रेंज दर्ज करें:</label>
                                <input type="text" id="split-range-val" placeholder="उदा: 1-2, 4, 6-8" class="w-full bg-slate-950 border border-slate-800 text-sm rounded-lg p-2.5 text-slate-300 focus:border-rose-500 focus:outline-none">
                            </div>
                            <div id="method-every-input" class="space-y-1.5 hidden">
                                <label class="text-xs text-slate-400">हर X पेज बाद काटें:</label>
                                <input type="number" id="split-every-val" min="1" value="1" class="w-full bg-slate-950 border border-slate-800 text-sm rounded-lg p-2.5 text-slate-300 focus:border-rose-500 focus:outline-none">
                            </div>
                        </div>

                        <button onclick="processSplit()" class="w-full mt-2 bg-rose-600 hover:bg-rose-700 text-white text-sm font-bold py-3 rounded-lg shadow-lg shadow-rose-600/10 active:scale-[0.98] transition-all flex items-center justify-center gap-2 cursor-pointer">
                            <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h18"/></svg>
                            PDF स्प्लिट करें और डाउनलोड करें
                        </button>
                    </div>
                </div>

                <!-- Preview Grid Right -->
                <div class="lg:col-span-2 bg-slate-900/20 border border-slate-800/80 rounded-2xl p-6 flex flex-col min-h-[400px]">
                    <h3 class="text-sm font-bold text-slate-400 mb-4 flex items-center gap-2">
                        <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                        दस्तावेज़ पेज प्रीव्यू देखें
                    </h3>
                    <div id="splitter-preview-grid" class="flex-1 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 overflow-y-auto max-h-[500px] custom-scrollbar p-2 justify-center items-center text-center text-slate-600 italic text-sm">
                        कोई PDF फ़ाइल लोड नहीं की गई है।
                    </div>
                </div>
            </div>
        </section>


        <!-- SECTION 2: PDF MERGER -->
        <section id="merger-section" class="space-y-6 hidden">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Dropzone left/top -->
                <div class="lg:col-span-1 space-y-4">
                    <div id="merge-dropzone" class="border-2 border-dashed border-slate-800 hover:border-indigo-500/50 bg-slate-900/30 rounded-2xl p-8 text-center cursor-pointer transition-all flex flex-col items-center justify-center min-h-[250px] shadow-sm">
                        <input type="file" id="merge-input" accept=".pdf" multiple class="hidden" onchange="handleMergeFiles(this.files)">
                        <div class="p-4 bg-indigo-500/10 rounded-full text-indigo-500 mb-4">
