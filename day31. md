<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Supply Chain Control Tower - Operations Simulation</title>
    <style>
        /* --- CSS Reset & Variables --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        :root {
            --bg-dark: #0a0f1d;
            --bg-card: #131c31;
            --bg-hover: #1b2744;
            --text-main: #e2e8f0;
            --text-muted: #94a3b8;
            --color-blue: #00e5ff;
            --color-cyan: #00b4d8;
            --color-red: #ff3366;
            --color-orange: #ff9f1c;
            --color-green: #2ec4b6;
            --shadow-glow: static;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            overflow-x: hidden;
            line-height: 1.5;
        }

        /* --- Header & Top Bar --- */
        header {
            background: linear-gradient(90deg, #111827 0%, var(--bg-card) 100%);
            padding: 15px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #1e293b;
            box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        }

        .logo-section h1 {
            font-size: 1.5rem;
            color: #fff;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo-section h1 span {
            color: var(--color-blue);
            text-shadow: 0 0 10px rgba(0, 229, 255, 0.5);
        }

        .logo-section p {
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        .controls-bar {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        button.btn-ctrl {
            background: #1e293b;
            color: #fff;
            border: 1px solid #334155;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        button.btn-ctrl:hover {
            background: var(--bg-hover);
            border-color: var(--color-cyan);
        }

        /* --- Main Layout --- */
        .dashboard-container {
            display: grid;
            grid-template-columns: 3fr 1fr;
            gap: 20px;
            padding: 20px;
            max-width: 1600px;
            margin: 0 auto;
            height: calc(100vh - 85px);
        }

        @media (max-width: 1024px) {
            .dashboard-container {
                grid-template-columns: 1fr;
                height: auto;
            }
        }

        .main-ops-panel {
            display: flex;
            flex-direction: column;
            gap: 20px;
            overflow-y: auto;
            padding-right: 5px;
        }

        /* --- KPIs Section --- */
        .kpis-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
        }

        @media (max-width: 768px) {
            .kpis-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        .kpi-card {
            background: var(--bg-card);
            border: 1px solid #1e293b;
            border-radius: 10px;
            padding: 15px;
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease, border-color 0.3s ease;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }

        .kpi-card:hover {
            transform: translateY(-2px);
            border-color: #2a3b61;
        }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--color-blue);
        }

        .kpi-card.cost::before { background: var(--color-orange); }
        .kpi-card.score::before { background: var(--color-green); }
        .kpi-card.timer::before { background: var(--color-red); }

        .kpi-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .kpi-value {
            font-size: 1.6rem;
            font-weight: 700;
            margin-top: 5px;
            color: #fff;
        }

        /* --- Alerts Section --- */
        .alerts-section-title {
            font-size: 1.1rem;
            color: var(--text-main);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 4px solid var(--color-blue);
            padding-left: 10px;
        }

        .alerts-container {
            display: flex;
            flex-direction: column;
            gap: 15px;
            min-height: 200px;
        }

        .alert-card {
            background: var(--bg-card);
            border-radius: 10px;
            border: 1px solid #1e293b;
            padding: 20px;
            position: relative;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            animation: slideIn 0.4s ease-out forwards;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Priority Colors */
        .alert-card.critical { border-left: 6px solid var(--color-red); box-shadow: 0 0 15px rgba(255, 51, 102, 0.15); }
        .alert-card.high { border-left: 6px solid var(--color-orange); box-shadow: 0 0 15px rgba(255, 159, 28, 0.15); }
        .alert-card.medium { border-left: 6px solid var(--color-cyan); }

        /* Pulse for Critical */
        .alert-card.critical .pulse-dot {
            width: 8px;
            height: 8px;
            background: var(--color-red);
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 0 0 rgba(255, 51, 102, 0.7);
            animation: pulse 1.2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 51, 102, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(255, 51, 102, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 51, 102, 0); }
        }

        .alert-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
        }

        .alert-title-area {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-title {
            font-size: 1.1rem;
            font-weight: 600;
        }

        .alert-meta {
            font-size: 0.8rem;
            background: rgba(255,255,255,0.05);
            padding: 4px 8px;
            border-radius: 4px;
            color: var(--text-muted);
        }

        .alert-desc {
            font-size: 0.9rem;
            color: #cbd5e1;
            margin-bottom: 15px;
        }

        .alert-impact {
            font-size: 0.8rem;
            background: rgba(0,0,0,0.2);
            padding: 8px 12px;
            border-radius: 6px;
            margin-bottom: 15px;
            border: 1px solid #1e293b;
            color: var(--text-muted);
        }

        .alert-impact span {
            color: #f1f5f9;
            font-weight: 500;
        }

        .alert-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .btn-action {
            background: #1e293b;
            color: #fff;
            border: 1px solid #334155;
            padding: 8px 14px;
            border-radius: 6px;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-action:hover {
            background: var(--color-cyan);
            color: #000;
            border-color: var(--color-cyan);
            font-weight: 600;
        }

        .btn-action.ignore {
            border-color: #475569;
            color: var(--text-muted);
        }

        .btn-action.ignore:hover {
            background: #475569;
            color: #fff;
        }

        /* --- Sidebar & Logs --- */
        .sidebar {
            display: flex;
            flex-direction: column;
            background: var(--bg-card);
            border: 1px solid #1e293b;
            border-radius: 12px;
            padding: 20px;
            height: 100%;
        }

        .sidebar h2 {
            font-size: 1.1rem;
            margin-bottom: 15px;
            padding-bottom: 8px;
            border-bottom: 2px solid #1e293b;
            color: var(--color-blue);
        }

        .log-container {
            flex-grow: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
            font-size: 0.8rem;
            padding-right: 5px;
        }

        .log-item {
            padding: 8px 12px;
            background: rgba(0, 0, 0, 0.2);
            border-left: 3px solid #475569;
            border-radius: 4px;
            animation: fadeIn 0.3s ease;
        }

        .log-item.success { border-left-color: var(--color-green); }
        .log-item.fail { border-left-color: var(--color-red); }
        .log-item.info { border-left-color: var(--color-blue); }

        .log-time {
            color: var(--text-muted);
            margin-right: 5px;
            font-family: monospace;
        }

        /* --- Modals --- */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
