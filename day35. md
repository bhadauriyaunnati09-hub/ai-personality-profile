<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🧩 Prompt Puzzle — Master AI Prompting Through Play</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://jsdelivr.net"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
            color: #f8fafc;
        }
        .heading-font {
            font-family: 'Space Grotesk', sans-serif;
        }
        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .glass-card {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-card:hover {
            transform: translateY(-2px);
            border-color: rgba(99, 102, 241, 0.4);
            box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.1);
        }
        .drag-item {
            cursor: grab;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .drag-item:active {
            cursor: grabbing;
            transform: scale(0.98);
        }
        .drop-zone-active {
            border-color: #6366f1 !important;
            background: rgba(99, 102, 241, 0.1) !important;
        }
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #0f172a;
        }
        ::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #475569;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col antialiased selection:bg-indigo-500 selection:text-white">

    <!-- Notification Toast Handler -->
    <div id="toast-container" class="fixed top-6 right-6 z-50 flex flex-col gap-3 pointer-events-none"></div>

    <!-- Header Section -->
    <header class="glass-panel sticky top-0 z-40 border-b border-slate-800 px-6 py-4">
        <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <span class="text-3xl animate-bounce">🧩</span>
                <div>
                    <h1 class="text-xl sm:text-2xl font-bold heading-font tracking-tight bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
                        Prompt Puzzle
                    </h1>
                    <p class="text-xs text-slate-400">Master AI Prompting Through Play</p>
                </div>
            </div>
            
            <!-- Global Stats Bar -->
            <div class="flex flex-wrap items-center justify-center gap-4 text-sm bg-slate-900/60 px-4 py-2 rounded-full border border-slate-800">
                <div class="flex items-center gap-1.5">
                    <span class="text-indigo-400 font-semibold">Domain:</span>
                    <span class="text-slate-300 font-medium" id="current-domain-tag">Tech & Coding</span>
                </div>
                <div class="h-4 w-px bg-slate-700 hidden sm:block"></div>
                <div class="flex items-center gap-1.5">
                    <span class="text-purple-400 font-semibold">Difficulty:</span>
                    <span class="text-slate-300 font-medium" id="current-diff-tag">Intermediate</span>
                </div>
                <div class="h-4 w-px bg-slate-700 hidden sm:block"></div>
                <div class="flex items-center gap-1.5">
                    <span class="text-emerald-400 font-semibold">Score:</span>
                    <span class="text-slate-200 font-bold transition-all duration-300" id="live-score">0</span>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow max-w-7xl w-full mx-auto p-4 sm:p-6 lg:p-8 flex flex-col gap-6">
        
        <!-- Game Dashboard View -->
        <div id="game-view" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- Left Panel: Context & Desired Output -->
            <div class="lg:col-span-1 flex flex-col gap-6">
                <!-- Progress Card -->
                <div class="glass-panel p-5 rounded-2xl">
                    <div class="flex justify-between items-center mb-3">
                        <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400">Campaign Progress</h3>
                        <span class="text-xs font-semibold bg-indigo-500/20 text-indigo-300 px-2 py-0.5 rounded" id="progress-text">Scenario 1 of 6</span>
                    </div>
                    <div class="w-full bg-slate-800 h-2 rounded-full overflow-hidden">
                        <div id="progress-bar" class="bg-gradient-to-r from-indigo-500 to-purple-500 h-full w-0 transition-all duration-500"></div>
                    </div>
                    <div class="grid grid-cols-3 gap-2 mt-4 text-center text-xs">
                        <div class="bg-slate-900/40 p-2 rounded-lg border border-slate-800">
                            <div class="text-slate-400 mb-0.5">Moves</div>
                            <div class="font-bold text-slate-200 text-sm" id="stat-moves">0</div>
                        </div>
                        <div class="bg-slate-900/40 p-2 rounded-lg border border-slate-800">
                            <div class="text-slate-400 mb-0.5">Errors</div>
                            <div class="font-bold text-rose-400 text-sm" id="stat-errors">0</div>
                        </div>
                        <div class="bg-slate-900/40 p-2 rounded-lg border border-slate-800">
                            <div class="text-slate-400 mb-0.5">Hints</div>
                            <div class="font-bold text-amber-400 text-sm" id="stat-hints">0</div>
                        </div>
                    </div>
                </div>

                <!-- Scenario Objective Card -->
                <div class="glass-panel p-6 rounded-2xl flex-grow flex flex-col gap-4">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="text-xs font-bold uppercase tracking-wider text-indigo-400" id="challenge-type-badge">Challenge Type</span>
                        </div>
                        <h2 class="text-xl font-bold heading-font text-slate-100" id="scenario-title">Scenario Loading...</h2>
                    </div>

                    <div class="bg-slate-900/80 p-4 rounded-xl border border-slate-800 flex-grow flex flex-col gap-2">
                        <h4 class="text-xs font-bold uppercase tracking-wider text-emerald-400 flex items-center gap-1.5">
                            <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span> Target AI Output Objective
                        </h4>
                        <div class="text-sm text-slate-300 overflow-y-auto max-h-[220px] pr-2 leading-relaxed whitespace-pre-line" id="desired-output-box">
                            Loading scenario target requirements...
                        </div>
                    </div>

                    <!-- Sandbox Controls / Context Actions -->
                    <div class="flex gap-2">
                        <button onclick="revealHint()" class="flex-1 bg-slate-800 hover:bg-slate-700 active:scale-95 text-slate-200 text-xs font-semibold py-2.5 px-4 rounded-xl border border-slate-700 transition-all flex items-center justify-center gap-1.5">
                            💡 Use Hint
                        </button>
                        <button onclick="showPrincipleModal()" class="flex-1 bg-slate-800/40 hover:bg-slate-800 text-slate-400 text-xs font-semibold py-2.5 px-4 rounded-xl border border-slate-800 transition-all flex items-center justify-center gap-1.5">
                            📖 Core Principle
                        </button>
                    </div>
                </div>
            </div>

            <!-- Right Panel: Interactive Gameplay Workspace -->
            <div class="lg:col-span-2 flex flex-col gap-6">
                <!-- Sandbox Canvas Area -->
                <div class="glass-panel p-6 rounded-2xl flex flex-col gap-4 flex-grow min-h-[450px]">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-slate-800 pb-3">
                        <div>
                            <h3 class="font-bold heading-font text-slate-200" id="workspace-title">Workspace Canvas</h3>
                            <p class="text-xs text-slate-400" id="workspace-desc">Arrange or fix the prompt segments below.</p>
                        </div>
                        <div class="text-xs text-slate-500 italic" id="timer-display">Time elapsed: 0s</div>
                    </div>

                    <!-- Core Interaction Container -->
                    <div id="interactive-container" class="flex-grow flex flex-col gap-4 justify-center">
                        <!-- Dynamic content injected here by JavaScript based on challenge type -->
                    </div>

                    <!-- Action Tray -->
                    <div class="flex items-center justify-between pt-4 border-t border-slate-800 mt-auto">
