<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prior Authorization Workflow Simulator</title>
    <style>
        /* Modern UI Design & Color Palette */
        :root {
            --primary: #1e40af;
            --primary-light: #dbeafe;
            --success: #16a34a;
            --success-light: #dcfce7;
            --warning: #d97706;
            --warning-light: #fef3c7;
            --danger: #dc2626;
            --danger-light: #fee2e2;
            --neutral-bg: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #0f172a;
            --text-muted: #475569;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--neutral-bg);
            color: var(--text-main);
            line-height: 1.5;
            padding: 20px;
        }

        /* Top Progress Tracker Header */
        header {
            background: var(--card-bg);
            border: 2px solid var(--primary);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 25px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .header-title {
            font-size: 24px;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .tracker-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }

        .tracker-card {
            background: var(--neutral-bg);
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            padding: 12px;
            text-align: center;
        }

        .tracker-label {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        .tracker-value {
            font-size: 20px;
            font-weight: 800;
            color: var(--text-main);
            margin-top: 4px;
        }

        /* Active Scenario & Control Board */
        .control-panel {
            background: var(--card-bg);
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 25px;
        }

        .panel-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 10px;
            color: var(--primary);
        }

        .btn {
            background-color: var(--primary);
            color: white;
            border: none;
            padding: 10px 20px;
            font-size: 14px;
            font-weight: 700;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn:hover {
            background-color: #1d4ed8;
        }

        .btn-success { background-color: var(--success); }
        .btn-success:hover { background-color: #15803d; }
        .btn-warning { background-color: var(--warning); color: white; }
        .btn-warning:hover { background-color: #b45309; }

        .document-checklist {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin: 15px 0;
            padding: 15px;
            background: var(--neutral-bg);
            border-radius: 8px;
            border: 1px dashed #94a3b8;
        }

        .check-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            cursor: pointer;
        }

        .check-item input {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        /* Interactive Lanes Layout */
        .lane-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 25px;
        }

        @media (max-width: 1024px) {
            .lane-container { grid-template-columns: 1fr; }
        }

        .lane {
            background: var(--card-bg);
            border: 2px solid #cbd5e1;
            border-radius: 12px;
            padding: 15px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            min-height: 450px;
        }

        .lane.active-drop {
            border-color: var(--primary);
            background-color: var(--primary-light);
        }

        .lane-header {
            font-size: 18px;
            font-weight: 800;
            text-align: center;
            padding-bottom: 10px;
            border-bottom: 2px solid #e2e8f0;
            text-transform: uppercase;
        }

        .lane-patient { border-top: 6px solid #60a5fa; }
        .lane-provider { border-top: 6px solid #2563eb; }
        .lane-payer { border-top: 6px solid #1e3a8a; }

        /* Draggable Patient Cards */
        .patient-card {
            background: #ffffff;
            border: 2px solid var(--text-main);
            border-radius: 8px;
            padding: 15px;
            cursor: grab;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .patient-card:active { cursor: grabbing; }
        .patient-card.dragging { opacity: 0.5; transform: scale(0.98); }

        .card-name { font-size: 16px; font-weight: 800; margin-bottom: 4px; }
        .card-badge {
            display: inline-block;
            font-size: 11px;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 4px;
            margin-top: 6px;
            text-transform: uppercase;
        }

        /* Educational Sidebar / Log Box */
        .edu-box {
            background: #eff6ff;
            border-left: 6px solid var(--primary);
            padding: 15px;
            border-radius: 0 8px 8px 0;
            margin-bottom: 25px;
        }

        .edu-title { font-weight: 800; font-size: 16px; margin-bottom: 5px; color: var(--primary); }

        /* Summary Modal Overlay */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(4px);
            justify-content: center; align-items: center;
            z-index: 1000;
        }

        .modal-content {
            background: white;
            border-radius: 16px;
            padding: 30px;
            max-width: 550px;
            width: 90%;
            border: 3px solid var(--primary);
            box-shadow: 0 20px 25px -5px rgba(0,0,0,0.2);
            text-align: center;
        }

        /* Celebration Animation Styling */
        .confetti-layer {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            z-index: 999;
            display: none;
        }

        .confetti {
            position: absolute;
            width: 10px; height: 10px;
            background-color: var(--primary);
            animation: fall 2.5s linear infinite;
        }

        @keyframes fall {
            0% { transform: translateY(-10px) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100vh) rotate(360deg); opacity: 0; }
        }
    </style>
</head>
<body>

    <!-- Confetti Canvas Layer -->
    <div id="confetti-container" class="confetti-layer"></div>

    <!-- Header Stats Tracker -->
    <header>
        <div class="header-title">Prior Authorization Workflow Simulator</div>
        <div class="tracker-grid">
            <div class="tracker-card">
                <div class="tracker-label">Current Stage</div>
                <div id="track-stage" class="tracker-value">Intake</div>
            </div>
            <div class="tracker-card">
                <div class="tracker-label">Days Elapsed</div>
                <div id="track-days" class="tracker-value">0 Days</div>
            </div>
            <div class="tracker-card">
                <div class="tracker-label">Efficiency Score</div>
                <div id="track-efficiency" class="tracker-value">100%</div>
            </div>
            <div class="tracker-card">
                <div class="tracker-label">Case Status</div>
                <div id="track-status" class="tracker-value">No Active Case</div>
            </div>
        </div>
    </header>

    <!-- Interactive Educational Commentary Box -->
    <div class="edu-box">
        <div class="edu-title">Educational Explanation</div>
        <div id="edu-text">Welcome to the Prior Authorization (PA) Simulator. To begin learning about healthcare utilization management, select or restart a patient scenario below.</div>
    </div>

    <!-- Active Management Console / Actions Panel -->
    <div class="control-panel">
        <div class="panel-title">Active Management & Controls</div>
        <div style="display:flex; flex-wrap: wrap; gap:10px; align-items: center; justify-content: space-between;">
            <div>
                <label style="font-weight: 700; margin-right: 10px;">Select Scenario:</label>
                <select id="scenario-select" style="padding: 8px; font-weight:600; border-radius:6px; border:1px solid #cbd5e1; margin-right: 10px;"></select>
                <button class="btn" onclick="loadSelectedScenario()">Launch Scenario</button>
            </div>
            <button class="btn btn-warning" onclick="resetSimulator()">Restart Simulator</button>
        </div>

        <!-- Dynamic Provider Documentation Section -->
