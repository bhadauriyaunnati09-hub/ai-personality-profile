<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Decision Report</title>
    <link href="https://googleapis.com" rel="stylesheet">
    <style>
        :root {
            --bg-main: #0f0f14;
            --bg-card: #1a1a24;
            --bg-card-alt: #1e1e2e;
            --text-primary: #f0f0f5;
            --text-secondary: #8888a0;
            --accent-green: #34d399;
            --accent-red: #f87171;
            --accent-blue: #60a5fa;
            --accent-gold: #fbbf24;
            --accent-purple: #a78bfa;
            --border-subtle: rgba(255,255,255,0.06);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-primary);
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            line-height: 1.7;
            padding: 40px 20px;
            scroll-behavior: smooth;
        }

        .container {
            max-width: 720px;
            margin: 0 auto;
        }

        /* HEADER */
        header {
            margin-bottom: 32px;
            text-align: left;
        }

        header h1 {
            font-size: 28px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.5px;
            margin-bottom: 4px;
        }

        header p.subtitle {
            font-size: 16px;
            color: var(--text-secondary);
            margin-bottom: 12px;
        }

        header p.date {
            font-size: 12px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .gradient-line {
            height: 2px;
            background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple), var(--accent-gold));
            margin-top: 16px;
            border-radius: 2px;
        }

        /* CARD STYLING */
        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 16px;
            padding: 24px 32px;
            margin-bottom: 24px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.3);
            transition: transform 0.2s ease;
        }

        .card:hover {
            transform: translateY(-2px);
        }

        .card-s1 { border-left: 4px solid var(--accent-blue); }
        .card-s2 { border-left: 4px solid var(--accent-green); }
        .card-s3 { border-left: 4px solid var(--accent-purple); }
        .card-s4 { border-left: 4px solid var(--accent-blue); }
        .card-s5 { border-left: 4px solid var(--accent-red); }
        .card-s6 { border-left: 4px solid var(--accent-green); }
        
        .card-s7 { 
            border-left: 4px solid var(--accent-gold); 
            background-color: var(--bg-card-alt);
            padding: 32px;
            box-shadow: 0 0 20px rgba(251,191,36,0.15);
        }
        
        .card-s8 { border-left: 4px solid var(--accent-gold); }

        .section-title {
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
        }
        
        .title-s1 { color: var(--accent-blue); }
        .title-s2 { color: var(--accent-green); }
        .title-s3 { color: var(--accent-purple); }
        .title-s4 { color: var(--accent-blue); }
        .title-s5 { color: var(--accent-red); }
        .title-s6 { color: var(--accent-green); }
        .title-s7 { color: var(--accent-gold); }
        .title-s8 { color: var(--accent-gold); }

        /* SECTION SPECIFIC STYLES */
        .text-content {
            font-size: 15px;
            color: var(--text-primary);
        }

        /* Section 2 Option Cards */
        .option-grid {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .option-sub-card {
            background-color: var(--bg-card-alt);
            border: 1px solid var(--border-subtle);
            border-radius: 12px;
            padding: 20px;
        }

        .option-sub-card h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 12px;
            color: var(--text-primary);
        }

        .bullet-list {
            list-style: none;
        }

        .bullet-list li {
            font-size: 14px;
            margin-bottom: 6px;
            padding-left: 16px;
            position: relative;
        }

        .bullet-list li::before {
            content: "•";
            position: absolute;
            left: 0;
            color: var(--text-secondary);
        }

        .bullet-list li span.label {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--text-secondary);
            display: inline-block;
            width: 90px;
        }

        /* Section 4 Matrix */
        .matrix-container {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .matrix-option-block h3 {
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 12px;
            color: var(--text-primary);
        }

        .matrix-row {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
        }

        .matrix-label {
            width: 40%;
            font-size: 13px;
            color: var(--text-secondary);
            padding-right: 12px;
        }

        .matrix-bar-container {
            width: 60%;
            height: 28px;
            background: rgba(255,255,255,0.05);
            border-radius: 8px;
            overflow: hidden;
            position: relative;
        }

        .matrix-bar-fill {
            height: 100%;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 12px;
            width: 0%;
            animation: fillBar 0.8s ease-out forwards;
        }

        .bar-opt-a { background: linear-gradient(90deg, #60a5fa, #3b82f6); }
        .bar-opt-b { background: linear-gradient(90deg, #34d399, #10b981); }

        .matrix-score {
            color: #ffffff;
            font-size: 12px;
            font-weight: 700;
        }

        .matrix-total-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255,255,255,0.03);
            padding: 12px 16px;
            border-radius: 8px;
            margin-top: 8px;
            border: 1px dashed var(--border-subtle);
        }

        .matrix-total-label {
            font-size: 14px;
            font-weight: 700;
        }

        .matrix-total-score {
            font-size: 16px;
            font-weight: 800;
        }
        
        .winner-highlight {
            color: var(--accent-gold);
            border: 1px solid rgba(251,191,36,0.3);
            background: rgba(251,191,36,0.05);
        }

        @keyframes fillBar {
            to { width: var(--target-width); }
        }

        /* Section 7 Verdict */
        .verdict-title {
            font-size: 32px;
            font-weight: 800;
            color: var(--accent-gold);
            margin-bottom: 12px;
            letter-spacing: -0.5px;
        }

        .hard-truth {
            font-style: italic;
            color: var(--text-secondary);
            margin-top: 16px;
            border-top: 1px solid var(--border-subtle);
            padding-top: 12px;
        }

        /* Section 8 Shareable Cards */
        .shareable-row {
            display: flex;
            gap: 16px;
        }

        .mini-card {
            flex: 1;
            background-color: var(--bg-card-alt);
            border: 1px solid var(--border-subtle);
            border-radius: 12px;
            padding: 16px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 140px;
            position: relative;
        }

        .mini-card-title {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--text-secondary);
            margin-bottom: 8px;
        }

        .mini-card-body {
            font-size: 13px;
            color: var(--text-primary);
            font-weight: 500;
        }

        .watermark {
            font-size: 9px;
            color: rgba(255,255,255,0.15);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 12px;
        }

        /* FOOTER */
        footer {
            text-align: center;
            color: var(--text-secondary);
            font-size: 12px;
            margin-top: 40px;
        }

        /* RESPONSIVE DESIGN */
        @media (max-width: 600px) {
            body { padding: 20px 12px; }
            .card { padding: 20px; }
            .matrix-row { flex-direction: column; align-items: flex-start; margin-bottom: 12px; }
            .matrix-label { width: 100%; margin-bottom: 4px; }
            .matrix-bar-container { width: 100%; }
            .shareable-row { flex-direction: column; }
            .mini-card { min-height: auto; }
            header h1 { font-size: 24px; }
            .verdict-title { font-size: 26px; }
        }
    </style>
</head>
<body>

    <div class="container">
        
        <!-- HEADER -->
        <header>
            <h1>DECISION REPORT</h1>
            <p class="subtitle">Higher Studies vs. Corporate Startup Strategy</p>
            <p class="date">JULY 2026</p>
            <div class="gradient-line"></div>
        </header>

