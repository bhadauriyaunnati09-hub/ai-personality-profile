<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Media Integrity Analyzer</title>
    <style>
        :root {
            --bg-dark: #0f1115;
            --bg-card: #161920;
            --bg-input: #1e222b;
            --text-main: #e2e8f0;
            --text-muted: #94a3b8;
            --border: #2d3139;
            
            /* Theme Variables - Default to Claude Orange */
            --primary: #d97706;
            --primary-rgb: 217, 119, 6;
            --primary-glow: rgba(217, 119, 6, 0.15);
            
            /* Metric Colors */
            --color-danger: #ef4444;
            --color-warning: #f59e0b;
            --color-success: #10b981;
            
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Alternate Themes */
        [data-theme="cyber-blue"] {
            --primary: #0284c7;
            --primary-rgb: 2, 132, 199;
            --primary-glow: rgba(2, 132, 199, 0.15);
        }
        [data-theme="emerald-green"] {
            --primary: #059669;
            --primary-rgb: 5, 150, 105;
            --primary-glow: rgba(5, 150, 105, 0.15);
        }
        [data-theme="royal-purple"] {
            --primary: #7c3aed;
            --primary-rgb: 124, 58, 237;
            --primary-glow: rgba(124, 58, 237, 0.15);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* Utility Classes */
        .hidden { display: none !important; }
        .highlight-red { background-color: rgba(239, 68, 68, 0.25); border-bottom: 2px dashed var(--color-danger); padding: 0 2px; }
        .highlight-amber { background-color: rgba(245, 158, 11, 0.25); border-bottom: 2px dashed var(--color-warning); padding: 0 2px; }

        /* Container Layout */
        .app-container {
            width: 100%;
            max-width: 900px;
            padding: 2rem 1.5rem;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        /* Top Header & Theme Selector */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            padding-bottom: 1.5rem;
        }

        .brand h1 {
            font-size: 1.75rem;
            font-weight: 700;
            letter-spacing: -0.025em;
            background: linear-gradient(to right, var(--text-main), var(--text-muted));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .brand p {
            font-size: 0.875rem;
            color: var(--text-muted);
        }

        .theme-selector {
            display: flex;
            gap: 0.5rem;
            background: var(--bg-card);
            padding: 0.35rem;
            border-radius: 9999px;
            border: 1px solid var(--border);
        }

        .theme-dot {
            width: 1.5rem;
            height: 1.5rem;
            border-radius: 50%;
            border: 2px solid transparent;
            cursor: pointer;
            transition: var(--transition);
        }
        .theme-dot:hover { transform: scale(1.1); }
        .theme-dot.active { border-color: var(--text-main); }
        .dot-orange { background-color: #d97706; }
        .dot-blue { background-color: #0284c7; }
        .dot-green { background-color: #059669; }
        .dot-purple { background-color: #7c3aed; }

        /* Live Metrics Banner */
        .metrics-panel {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1rem;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.25rem;
        }

        .metric-card {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .metric-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
        }

        .metric-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-main);
            transition: var(--transition);
        }

        .metric-bar-bg {
            height: 4px;
            background: var(--bg-input);
            border-radius: 2px;
            overflow: hidden;
            margin-top: 0.25rem;
        }

        .metric-bar-fill {
            height: 100%;
            width: 0%;
            background: var(--primary);
            transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Screen & Card Configurations */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
            transition: var(--transition);
            animation: fadeIn 0.4s ease-out forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Educational Concept Intros */
        .concept-intro {
            border-left: 3px solid var(--primary);
            padding-left: 1.25rem;
            margin-bottom: 2rem;
        }
        .concept-intro h3 {
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
            color: var(--text-main);
        }
        .concept-intro p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* Simulation/Media Pieces */
        .media-artifact {
            background: var(--bg-dark);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .artifact-headline {
            font-family: Georgia, serif;
            font-size: 1.6rem;
            font-weight: 700;
            line-height: 1.3;
            margin-bottom: 1rem;
            color: #fff;
        }

        .artifact-body {
            font-size: 1rem;
            color: #cbd5e1;
            white-space: pre-line;
        }

        /* User Interactive Elements */
        .question-group {
            margin-bottom: 2rem;
        }

        .question-label {
            font-weight: 600;
            margin-bottom: 0.75rem;
            display: block;
        }

        .btn-group {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .btn-opt {
            background: var(--bg-input);
            border: 1px solid var(--border);
            color: var(--text-main);
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            transition: var(--transition);
        }

        .btn-opt:hover {
            border-color: var(--primary);
            background: var(--primary-glow);
        }

        .btn-opt.selected {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
            box-shadow: 0 0 12px var(--primary-glow);
        }

        .word-picker {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            background: var(--bg-input);
            padding: 1rem;
            border-radius: 8px;
            border: 1px solid var(--border);
        }

        .selectable-word {
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            background: rgba(255,255,255,0.05);
            cursor: pointer;
            transition: var(--transition);
            border: 1px solid transparent;
        }

        .selectable-word:hover {
            background: rgba(255,255,255,0.1);
        }

        .selectable-word.active {
            background: var(--primary-glow);
            border-color: var(--primary);
            color: var(--text-main);
        }

        /* Action Buttons */
        .btn-prime {
            background: var(--primary);
            color: #fff;
            border: none;
            padding: 0.85rem 2rem;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
        }

        .btn-prime:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        /* Discovery & Reveal Subsections */
        .reveal-box {
            margin-top: 2rem;
            padding-top: 2rem;
            border-top: 1px solid var(--border);
            animation: fadeIn 0.5s ease-out forwards;
        }

        .analysis-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-top: 1.5rem;
        }

        .analysis-block {
            background: var(--bg-input);
            padding: 1.25rem;
            border-radius: 8px;
            border-left: 3px solid var(--primary);
        }

        .analysis-block h4 {
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 0.05em;
        }

        .score-pill {
