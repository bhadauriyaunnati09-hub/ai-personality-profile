<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Compass - Startup Edition</title>
    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-hover: rgba(255, 255, 255, 0.08);
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --accent-primary: #6366f1;
            --accent-secondary: #ec4899;
            --color-success: #10b981;
            
            /* Role Palette */
            --col-ceo: #f59e0b;
            --col-dev: #3b82f6;
            --col-mkt: #10b981;
            --col-dsn: #8b5cf6;
            --col-cs: #ec4899;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: var(--bg-gradient);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 800px;
            display: flex;
            flex-direction: column;
            gap: 24px;
            margin-top: 10px;
        }

        header {
            text-align: center;
            margin-bottom: 10px;
        }

        header h1 {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(to right, #a5b4fc, #f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 6px;
            letter-spacing: -0.05em;
        }

        header p {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        /* Progress Bar */
        .progress-container {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            padding: 12px 20px;
            border-radius: 16px;
            backdrop-filter: blur(12px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .stage-title {
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--accent-secondary);
            min-width: 140px;
        }

        .bar-wrapper {
            flex-grow: 1;
            background: rgba(255, 255, 255, 0.05);
            height: 8px;
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }

        .bar-fill {
            background: linear-gradient(to right, var(--accent-primary), var(--accent-secondary));
            height: 100%;
            width: 0%;
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .step-counter {
            font-size: 0.85rem;
            color: var(--text-secondary);
            font-weight: 600;
        }

        /* Screen Panel Card */
        .panel {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 30px;
            backdrop-filter: blur(20px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            display: none;
            flex-direction: column;
            gap: 24px;
            animation: fadeIn 0.4s ease-out;
        }

        .panel.active {
            display: flex;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .instruction-text {
            font-size: 1.1rem;
            color: var(--text-secondary);
            line-height: 1.5;
        }

        /* Ticket Styled Task Card */
        .ticket {
            background: rgba(15, 23, 42, 0.6);
            border-left: 4px solid var(--accent-primary);
            border-radius: 12px;
            padding: 20px;
            position: relative;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
            overflow: hidden;
        }

        .ticket::before, .ticket::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 16px;
            background: #121434;
            border-radius: 50%;
            right: -8px;
        }
        .ticket::before { top: -8px; }
        .ticket::after { bottom: -8px; }

        .ticket-tag {
            font-size: 0.75rem;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--accent-primary);
            letter-spacing: 0.1em;
            margin-bottom: 6px;
        }

        .ticket-title {
            font-size: 1.25rem;
            font-weight: 600;
            line-height: 1.4;
        }

        /* Role Cards Grids */
        .roles-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
            gap: 12px;
            margin-top: 10px;
        }

        .role-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            padding: 16px;
            border-radius: 16px;
            text-align: center;
            cursor: pointer;
            user-select: none;
            transition: all 0.2s ease;
            position: relative;
            font-weight: 600;
            font-size: 0.95rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        .role-card:hover {
            background: var(--glass-hover);
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        }

        .role-card.selected {
            border-color: var(--accent-secondary);
            background: rgba(236, 72, 153, 0.1);
        }

        .role-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            background: rgba(255,255,255,0.05);
        }

        /* Slots Layouts */
        .slot-zone {
            background: rgba(0,0,0,0.2);
            border: 2px dashed rgba(255,255,255,0.15);
            border-radius: 16px;
            padding: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 90px;
            transition: all 0.3s ease;
        }

        .slot-zone.highlight {
            border-color: var(--accent-primary);
            background: rgba(99, 102, 241, 0.05);
        }

        /* Stage 2 Sequence Slots */
        .routing-zone {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
            justify-content: center;
            background: rgba(0,0,0,0.2);
            border: 2px dashed rgba(255,255,255,0.15);
            border-radius: 16px;
            padding: 20px;
            min-height: 100px;
        }

        .routing-arrow {
            color: var(--text-secondary);
            font-weight: bold;
            animation: pulse 1.5s infinite;
        }

        /* Feedback Panels */
        .feedback-box {
            background: rgba(16, 185, 129, 0.08);
            border: 1px solid rgba(16, 185, 129, 0.2);
            border-radius: 16px;
            padding: 20px;
            display: none;
            flex-direction: column;
            gap: 10px;
            animation: slideUp 0.3s ease-out;
        }

        @keyframes slideUp {
            from { transform: translateY(10px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .feedback-header {
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 1.1rem;
        }

        .feedback-desc {
            font-size: 0.95rem;
            color: var(--text-secondary);
            line-height: 1.5;
        }

        .feedback-roles {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-top: 6px;
        }

        .mini-badge {
            font-size: 0.75rem;
            padding: 4px 10px;
            border-radius: 20px;
            background: rgba(255,255,255,0.08);
            font-weight: 600;
        }

        /* Buttons & Actions */
        .btn {
            background: linear-gradient(135deg, var(--accent-primary) 0%, #4f46e5 100%);
            color: white;
            border: none;
            padding: 14px 28px;
            font-size: 1rem;
            font-weight: 600;
            border-radius: 14px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
        }

        .btn:hover {
            opacity: 0.95;
            transform: translateY(-1px);
        }

        .btn:disabled {
            background: rgba(255,255,255,0.05);
            color: var(--text-secondary);
            cursor: not-allowed;
            box-shadow: none;
        }

        /* Dashboard & Charts */
        .chart-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
            margin: 15px 0;
        }

